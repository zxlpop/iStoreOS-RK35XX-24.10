 * Ported for iStoreOS by iStoreOS-Native project
 */

/dts-v1/;

#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/input/input.h>
#include <dt-bindings/leds/common.h>
#include <dt-bindings/pinctrl/rockchip.h>
#include <dt-bindings/soc/rockchip,vop2.h>
#include <rockchip/rk3568.dtsi>

/ {
	model = "BenDian One";
	compatible = "bendian,bd-one", "rockchip,rk3568";

	aliases {
		ethernet0 = &gmac0;
		ethernet1 = &gmac1;
		mmc0 = &sdhci;
		led-boot     = &led_power;
		led-failsafe = &led_power;
		led-running  = &led_power;
		led-upgrade  = &led_power;
	};

	chosen {
		stdout-path = "serial2:1500000n8";
	};

	/* ------------------------------------------------------------------ */
	/*  Memory-reserved: CMA pool                                          */
	/* ------------------------------------------------------------------ */
	reserved-memory {
		#address-cells = <2>;
		#size-cells = <2>;
		ranges;

		cma: linux,cma {
			compatible = "shared-dma-pool";
			reusable;
			size = <0x0 0x10000000>;
			linux,cma-default;
		};
	};

	/* ------------------------------------------------------------------ */
	/*  LEDs                                                               */
	/* ------------------------------------------------------------------ */
	gpio-leds {
		compatible = "gpio-leds";
		pinctrl-names = "default";
		pinctrl-0 = <&power_led_pin &status_led_pin>;

		led_power: led-0 {
			label = "red:power";
			gpios = <&gpio4 RK_PB3 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_RED>;
			function = LED_FUNCTION_POWER;
			linux,default-trigger = "default-on";
		};

		led-1 {
			label = "green:status";
			gpios = <&gpio4 RK_PA1 GPIO_ACTIVE_LOW>;
			color = <LED_COLOR_ID_GREEN>;
			function = LED_FUNCTION_STATUS;
			linux,default-trigger = "heartbeat";
		};
	};

	/* ------------------------------------------------------------------ */
	/*  GPIO Fan                                                           */
	/* ------------------------------------------------------------------ */
	gpio-fan {
		compatible = "gpio-fan";
		gpios = <&gpio4 RK_PA7 GPIO_ACTIVE_HIGH>;
		gpio-fan,speed-map = <0 0 7500 1>;
		pinctrl-names = "default";
		pinctrl-0 = <&fan_pins>;
		#cooling-cells = <2>;
	};

	/* ------------------------------------------------------------------ */
	/*  HDMI connector                                                     */
	/* ------------------------------------------------------------------ */
	hdmi-con {
		compatible = "hdmi-connector";
		type = "a";

		port {
			hdmi_con_in: endpoint {
				remote-endpoint = <&hdmi_out_con>;
			};
		};
	};

	/* ------------------------------------------------------------------ */
	/*  HDMI sound card                                                    */
	/* ------------------------------------------------------------------ */
	hdmi-sound {
		compatible = "simple-audio-card";
		simple-audio-card,name = "HDMI";
		simple-audio-card,format = "i2s";
		simple-audio-card,mclk-fs = <256>;
		status = "okay";

		simple-audio-card,codec {
			sound-dai = <&hdmi>;
		};

		simple-audio-card,cpu {
			sound-dai = <&i2s0_8ch>;
		};
	};

	/* ------------------------------------------------------------------ */
	/*  ADC recovery button                                                */
	/* ------------------------------------------------------------------ */
	adc-keys {
		compatible = "adc-keys";
		io-channels = <&saradc 0>;
		io-channel-names = "buttons";
		keyup-threshold-microvolt = <1800000>;
		poll-interval = <100>;

		button-recovery {
			label = "Recovery";
			linux,code = <KEY_VENDOR>;
			press-threshold-microvolt = <1750>;
		};
	};

	/* ------------------------------------------------------------------ */
	/*  Power supply rails                                                 */
	/* ------------------------------------------------------------------ */
	vcc12v_dcin: vcc12v-dcin {
		compatible = "regulator-fixed";
		regulator-name = "vcc12v_dcin";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <12000000>;
		regulator-max-microvolt = <12000000>;
	};

	vcc3v3_sys: vcc3v3-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc12v_dcin>;
	};

	vcc5v0_sys: vcc5v0-sys {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_sys";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc12v_dcin>;
	};

	/* 5V USB power controlled by GPIO0_B1 */
	vcc5v0_usb: vcc5v0-usb {
		compatible = "regulator-fixed";
		regulator-name = "vcc5v0_usb";
		enable-active-high;
		gpio = <&gpio0 RK_PB1 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&usb_pwr_en>;
		regulator-min-microvolt = <5000000>;
		regulator-max-microvolt = <5000000>;
		vin-supply = <&vcc5v0_sys>;
	};

	vcc_3v3: vcc-3v3 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_3v3";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc3v3_sys>;
	};

	vcc_1v8: vcc-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcc_1v8";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		vin-supply = <&vcc3v3_sys>;
	};

	vcca_1v8: vcca-1v8 {
		compatible = "regulator-fixed";
		regulator-name = "vcca_1v8";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <1800000>;
		regulator-max-microvolt = <1800000>;
		vin-supply = <&vcc3v3_sys>;
	};

	vdda_0v9: vdda-0v9 {
		compatible = "regulator-fixed";
		regulator-name = "vdda_0v9";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <900000>;
		regulator-max-microvolt = <900000>;
		vin-supply = <&vcc3v3_sys>;
	};

	/* PCIe 3.0 SSD power: GPIO0_B0 enable → vcc3v3_pi6c_03 → vcc3v3_pcie */
	vcc3v3_pi6c_03: vcc3v3-pi6c-03 {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_pi6c_03";
		enable-active-high;
		gpio = <&gpio0 RK_PB0 GPIO_ACTIVE_HIGH>;
		pinctrl-names = "default";
		pinctrl-0 = <&ssd_pwr_en>;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc12v_dcin>;
	};

	vcc3v3_pcie: vcc3v3-pcie {
		compatible = "regulator-fixed";
		regulator-name = "vcc3v3_pcie";
		regulator-always-on;
		regulator-boot-on;
		regulator-min-microvolt = <3300000>;
		regulator-max-microvolt = <3300000>;
		vin-supply = <&vcc3v3_pi6c_03>;
	};

	/* GPU voltage: PWM4 controlled */
	vdd_gpu: vdd-gpu {
		compatible = "pwm-regulator";
		pwms = <&pwm4 0 5000 1>;
		pwm-supply = <&vcc3v3_sys>;
		regulator-name = "vdd_gpu";
		regulator-always-on;
		regulator-boot-on;
		regulator-init-microvolt = <900000>;
		regulator-min-microvolt = <500000>;
		regulator-max-microvolt = <1350000>;
		regulator-ramp-delay = <6001>;
		regulator-settling-time-up-us = <250>;
	};

	/* Logic voltage: PWM5 controlled */
	vdd_logic: vdd-logic {
		compatible = "pwm-regulator";
		pwms = <&pwm5 0 5000 1>;
		pwm-supply = <&vcc3v3_sys>;
		regulator-name = "vdd_logic";
		regulator-always-on;
		regulator-boot-on;
		regulator-init-microvolt = <900000>;
		regulator-min-microvolt = <500000>;
		regulator-max-microvolt = <1350000>;
		regulator-ramp-delay = <6001>;
		regulator-settling-time-up-us = <250>;
	};
};

/* ====================================================================== */
/*  CPU / GPU power domains                                               */
/* ====================================================================== */
&cpu0 {
	cpu-supply = <&vdd_cpu>;
};

&cpu1 {
	cpu-supply = <&vdd_cpu>;
};

&cpu2 {
	cpu-supply = <&vdd_cpu>;
};

&cpu3 {
	cpu-supply = <&vdd_cpu>;
};

&gpu {
	mali-supply = <&vdd_gpu>;
	status = "okay";
};

/* ====================================================================== */
/*  Combo PHYs                                                            */
/* ====================================================================== */
/* combphy0 → SATA0 */
&combphy0 {
	status = "okay";
};

/* combphy1 → SATA1 (port 1) / USB 3.0 OTG */
&combphy1 {
	status = "okay";
};

/* combphy2 → PCIe 2.0 (NVMe SSD on pcie20) */
&combphy2 {
	status = "okay";
};

/* ====================================================================== */
/*  SATA                                                                  */
/* ====================================================================== */
&sata0 {
	status = "okay";
};

/* ====================================================================== */
/*  eMMC                                                                  */
/* ====================================================================== */
&sdhci {
	bus-width = <8>;
	max-frequency = <200000000>;
	non-removable;
	mmc-hs400-1_8v;
	mmc-hs400-enhanced-strobe;
	vmmc-supply = <&vcc_3v3>;
	vqmmc-supply = <&vcc_1v8>;
	pinctrl-names = "default";
	pinctrl-0 = <&emmc_bus8 &emmc_clk &emmc_cmd>;
	status = "okay";
};

/* ====================================================================== */
/*  USB                                                                   */
/* ====================================================================== */
/* USB 3.0 OTG (Type-C / Type-A) */
&usb2phy0 {
	status = "okay";
};

&usb2phy0_host {
	phy-supply = <&vcc5v0_usb>;
	status = "okay";
};

&usb2phy0_otg {
	phy-supply = <&vcc5v0_usb>;
	status = "okay";
};

&usb_host0_xhci {
	dr_mode = "host";
	phys = <&usb2phy0_otg>, <&combphy1 PHY_TYPE_USB3>;
	phy-names = "usb2-phy", "usb3-phy";
	status = "okay";
};

/* USB 2.0 Host (EHCI/OHCI) */
&usb2phy1 {
	status = "okay";
};

&usb2phy1_host {
	phy-supply = <&vcc5v0_usb>;
	status = "okay";
};

&usb2phy1_otg {
	status = "okay";
};

&usb_host0_ehci {
	status = "okay";
};

&usb_host0_ohci {
	status = "okay";
};

/* ====================================================================== */
/*  PCIe                                                                  */
/* ====================================================================== */
/* PCIe 2.0 x1 — NVMe SSD */
&pcie2x1 {
	reset-gpios = <&gpio3 RK_PB1 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc3v3_sys>;
	pinctrl-names = "default";
	pinctrl-0 = <&pcie20_reset_pin>;
	status = "okay";
};

/* PCIe 3.0 x2 — (available, e.g. dual NVMe or other) */
&pcie30phy {
	status = "okay";
};

&pcie3x2 {
	reset-gpios = <&gpio0 RK_PB6 GPIO_ACTIVE_HIGH>;
	vpcie3v3-supply = <&vcc3v3_pcie>;
	pinctrl-names = "default";
	pinctrl-0 = <&pcie30_reset_pin>;
	status = "okay";
};

/* ====================================================================== */
/*  Ethernet                                                              */
/* ====================================================================== */
/*
 * GMAC0 — connected to RTL8365MB 5-port switch
 * 4× LAN ports (lan1~lan4) + 1× CPU port (port7, fixed 1Gbps)
 */
&gmac0 {
	assigned-clocks = <&cru SCLK_GMAC0_RX_TX>, <&cru CLK_MAC0_OUT>;
	assigned-clock-parents = <&cru SCLK_GMAC0_RGMII_SPEED>;
	assigned-clock-rates = <0>, <125000000>;
	clock_in_out = "output";
	phy-mode = "rgmii";
	pinctrl-names = "default";
	pinctrl-0 = <&gmac0_miim
		     &gmac0_tx_bus2
		     &gmac0_rx_bus2
		     &gmac0_rgmii_clk
		     &gmac0_rgmii_bus>;
	tx_delay = <0x4f>;
	rx_delay = <0x0f>;
	status = "okay";

	fixed-link {
		speed = <1000>;
		full-duplex;
	};

	mdio {
		compatible = "snps,dwmac-mdio";
		#address-cells = <1>;
		#size-cells = <0>;

		/* RTL8365MB 5-port switch */
		switch@1d {
			compatible = "realtek,rtl8365mb";
			reg = <0x1d>;
			reset-gpios = <&gpio0 RK_PA3 GPIO_ACTIVE_LOW>;

			interrupt-controller;
			#address-cells = <0>;
			#interrupt-cells = <1>;
			interrupt-parent = <&gpio0>;
			interrupts = <RK_PA4 IRQ_TYPE_LEVEL_LOW>;

			ports {
				#address-cells = <1>;
				#size-cells = <0>;

				port@0 {
					reg = <0>;
					label = "lan4";
				};

				port@1 {
					reg = <1>;
					label = "lan3";
				};

				port@2 {
					reg = <2>;
					label = "lan2";
				};

				port@3 {
					reg = <3>;
					label = "lan1";
				};

				port@7 {
					reg = <7>;
					label = "cpu";
					ethernet = <&gmac0>;
					phy-mode = "rgmii";

					fixed-link {
						speed = <1000>;
						full-duplex;
					};
				};
			};
		};
	};
};

/*
 * GMAC1 — direct RTL8211 PHY (1× WAN)
 */
&gmac1 {
	assigned-clocks = <&cru SCLK_GMAC1_RX_TX>, <&cru CLK_MAC1_OUT>;
	assigned-clock-parents = <&cru SCLK_GMAC1_RGMII_SPEED>;
	assigned-clock-rates = <0>, <125000000>;
	clock_in_out = "output";
	phy-mode = "rgmii";
	phy-handle = <&rgmii_phy1>;
	phy-supply = <&vcc_3v3>;
	pinctrl-names = "default";
	pinctrl-0 = <&gmac1m0_miim
		     &gmac1m0_tx_bus2
		     &gmac1m0_rx_bus2
		     &gmac1m0_rgmii_clk
		     &gmac1m0_rgmii_bus>;
	snps,reset-gpio = <&gpio1 RK_PB6 GPIO_ACTIVE_LOW>;
	snps,reset-active-low;
	snps,reset-delays-us = <0 20000 100000>;
	tx_delay = <0x30>;
	rx_delay = <0x10>;
	status = "okay";
};

&mdio1 {
	rgmii_phy1: ethernet-phy@0 {
		compatible = "ethernet-phy-ieee802.3-c22";
		reg = <0>;
		realtek,led-data = <0x17b>;
	};
};

/* ====================================================================== */
/*  I2C0 — CPU voltage regulator (TCS4525)                               */
/* ====================================================================== */
&i2c0 {
	status = "okay";

	vdd_cpu: regulator@1c {
		compatible = "tcs,tcs4525";
		reg = <0x1c>;
		fcs,suspend-voltage-selector = <1>;
		regulator-name = "vdd_cpu";
		regulator-always-on;
		regulator-boot-on;
		regulator-init-microvolt = <900000>;
		regulator-min-microvolt = <712500>;
		regulator-max-microvolt = <1390000>;
		regulator-ramp-delay = <2300>;
		vin-supply = <&vcc3v3_sys>;

		regulator-state-mem {
			regulator-off-in-suspend;
		};
	};
};

/* ====================================================================== */
/*  I2C3 — board peripherals                                             */
/* ====================================================================== */
&i2c3 {
	status = "okay";
};

/* ====================================================================== */
/*  HDMI                                                                  */
/* ====================================================================== */
&hdmi {
	avdd-0v9-supply = <&vdda_0v9>;
	avdd-1v8-supply = <&vcca_1v8>;
	status = "okay";
};

&hdmi_in {
	hdmi_in_vp0: endpoint {
		remote-endpoint = <&vp0_out_hdmi>;
	};
};

&hdmi_out {
	hdmi_out_con: endpoint {
		remote-endpoint = <&hdmi_con_in>;
	};
};

&hdmi_sound {
	status = "okay";
};

/* ====================================================================== */
/*  VOP                                                                   */
/* ====================================================================== */
&vop {
	assigned-clocks = <&cru DCLK_VOP0>, <&cru DCLK_VOP1>;
	assigned-clock-parents = <&pmucru PLL_HPLL>, <&cru PLL_VPLL>;
	status = "okay";
};

&vop_mmu {
	status = "okay";
};

&vp0 {
	vp0_out_hdmi: endpoint@ROCKCHIP_VOP2_EP_HDMI0 {
		reg = <ROCKCHIP_VOP2_EP_HDMI0>;
		remote-endpoint = <&hdmi_in_vp0>;
	};
};

/* ====================================================================== */
/*  Audio (I2S0 → HDMI)                                                  */
/* ====================================================================== */
&i2s0_8ch {
	status = "okay";
};

/* ====================================================================== */
/*  PWM regulators                                                        */
/* ====================================================================== */
&pwm4 {
	status = "okay";
};

&pwm5 {
	status = "okay";
};

/* ====================================================================== */
/*  Thermal / TSADC                                                       */
/* ====================================================================== */
&tsadc {
	rockchip,hw-tshut-mode = <1>;    /* CRU reset */
	rockchip,hw-tshut-polarity = <0>;/* active low */
	status = "okay";
};

/* ====================================================================== */
/*  SARADC                                                                */
/* ====================================================================== */
&saradc {
	vref-supply = <&vcca_1v8>;
	status = "okay";
};

/* ====================================================================== */
/*  Crypto / RNG                                                          */
/* ====================================================================== */
&crypto {
	status = "okay";
};

/* ====================================================================== */
/*  IO Domains (PMU GRF)                                                  */
/* ====================================================================== */
&pmu_io_domains {
	pmuio1-supply = <&vcc_3v3>;
	pmuio2-supply = <&vcc_3v3>;
	vccio1-supply = <&vcc_3v3>;
	vccio2-supply = <&vcc_1v8>;
	vccio3-supply = <&vcc_3v3>;
	vccio4-supply = <&vcc_3v3>;
	vccio5-supply = <&vcc_3v3>;
	vccio6-supply = <&vcc_3v3>;
	vccio7-supply = <&vcc_3v3>;
	status = "okay";
};

/* ====================================================================== */
/*  UART2 — debug console                                                 */
/* ====================================================================== */
&uart2 {
	status = "okay";
};

/* ====================================================================== */
/*  Pinctrl additions                                                     */
/* ====================================================================== */
&pinctrl {

	fan {
		fan_pins: fan-pins {
			rockchip,pins = <4 RK_PA7 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	gpio-leds {
		power_led_pin: power-led-pin {
			rockchip,pins = <4 RK_PB3 RK_FUNC_GPIO &pcfg_pull_none>;
		};

		status_led_pin: status-led-pin {
			rockchip,pins = <4 RK_PA1 RK_FUNC_GPIO &pcfg_pull_none>;
		};
	};

	pcie20 {
		pcie20_reset_pin: pcie20-reset-pin {
			rockchip,pins = <3 RK_PB1 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	pcie30 {
		pcie30_reset_pin: pcie30-reset-pin {
			rockchip,pins = <0 RK_PB6 RK_FUNC_GPIO &pcfg_pull_down>;
		};

		ssd_pwr_en: ssd-pwr-en {
			rockchip,pins = <0 RK_PB0 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};

	usb {
		usb_pwr_en: usb-pwr-en {
			rockchip,pins = <0 RK_PB1 RK_FUNC_GPIO &pcfg_pull_down>;
		};
	};
};
